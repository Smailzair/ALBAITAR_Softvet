  <Code>Function ConvertToFrenchLetters(ByVal value As Double) As String
    ' Define the words for numbers from 0 to 19 '
    Dim unitsWords() As String = {"zéro", "un", "deux", "trois", "quatre", "cinq", "six", "sept", "huit", "neuf", "dix",
                                  "onze", "douze", "treize", "quatorze", "quinze", "seize", "dix-sept", "dix-huit", "dix-neuf"}

    ' Define the words for tens from 20 to 90 '
    Dim tensWords() As String = {"", "", "vingt", "trente", "quarante", "cinquante", "soixante", "", "quatre-vingt"}

    ' Convert the value to an integer and handle edge cases '
    Dim intValue As Integer = CInt(Math.Floor(value))
    Dim decimalValue As Integer = CInt(Math.Round((value - intValue) * 100)) ' Convert decimal part to integer
    If intValue = 0 And decimalValue = 0 Then
        Return "zéro DA" ' Return "zéro DA" if the value is 0
    ElseIf intValue &lt; 0 Or intValue &gt; 999999999 Or decimalValue &gt; 99 Then
        Return "" ' Handle invalid or out-of-range values
    End If

    ' Split the value into billions, millions, thousands, and units '
    Dim billions As Integer = intValue \ 1000000000
    Dim millions As Integer = (intValue \ 1000000) Mod 1000
    Dim thousands As Integer = (intValue \ 1000) Mod 1000
    Dim units As Integer = intValue Mod 1000

    ' Build the result string by converting each part of the value to words '
    Dim result As String = ""
    If billions &gt; 0 Then
        result += ConvertGroupToFrenchLetters(billions) + " milliard"
        If billions &gt; 1 Then
            result += "s"
        End If
    End If
    If millions &gt; 0 Then
        If result &lt;&gt; "" Then
            result += " "
        End If
        result += ConvertGroupToFrenchLetters(millions) + " million"
        If millions &gt; 1 Then
            result += "s"
        End If
    End If
    If thousands &gt; 0 Then
        If result &lt;&gt; "" Then
            result += " "
        End If
        result += ConvertGroupToFrenchLetters(thousands) + " mille"
    End If
    If units &gt; 0 Then
        If result &lt;&gt; "" Then
            result += " "
        End If
        result += ConvertGroupToFrenchLetters(units)
    End If

    If result &lt;&gt; "" Then
        result += " DA"
    End If

    If decimalValue &gt; 0 Then
        If result &lt;&gt; "" Then
            result += " et "
        End If
        result += ConvertGroupToFrenchLetters(decimalValue) + " Cts"      
    End If

If Not String.IsNullOrEmpty(result) Then
        result = Char.ToUpper(result(0)) + result.Substring(1) ' Capitalize the first letter
    End If

    Return result
End Function

Function ConvertGroupToFrenchLetters(ByVal groupValue As Integer) As String
    ' Define the words for numbers from 0 to 9 '
    Dim unitsWords() As String = {"", "un", "deux", "trois", "quatre", "cinq", "six", "sept", "huit", "neuf"}

    ' Define the words for tens from 10 to 90 '
    Dim tensWords() As String = {"", "", "vingt", "trente", "quarante", "cinquante", "soixante", "", "quatre-vingt"}

    ' Convert the group value to words '
    Dim result As String = ""

    Dim hundreds As Integer = groupValue \ 100
    Dim tens As Integer = (groupValue \ 10) Mod 10
    Dim units As Integer = groupValue Mod 10

    If hundreds &gt; 0 Then
        result += unitsWords(hundreds) + " cent"
        If tens = 0 AndAlso units = 0 Then
            result += "s"
        End If
    End If

    If tens = 7 Or tens = 9 Then
        units += 10
    End If

    If tens &gt; 1 Then
        result += " " + tensWords(tens)
        If units &gt; 0 Then
            result += "-" + unitsWords(units)
        End If
    ElseIf tens = 1 Then
        If units = 0 Then
            result += " dix"
        ElseIf units = 1 Then
            result += " onze"
        ElseIf units = 2 Then
            result += " douze"
        ElseIf units = 3 Then
            result += " treize"
        ElseIf units = 4 Then
            result += " quatorze"
        ElseIf units = 5 Then
            result += " quinze"
        ElseIf units = 6 Then
            result += " seize"
        Else
            result += " dix-" + unitsWords(units)
        End If
    ElseIf units &gt; 0 Then
        result += " " + unitsWords(units)
    End If

    Return result.Trim()
End Function


Function PageNumber() As String    
    Return Me.Report.Globals!PageNumber    
End Function

Function TotalPages() As String   
    Return Me.Report.Globals!TotalPages    
End Function</Code>
